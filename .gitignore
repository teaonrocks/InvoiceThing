/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# testing
/coverage

# production
/build
/.output

# misc
.DS_Store
Thumbs.db
*.pem

